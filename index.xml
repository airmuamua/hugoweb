		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;243&#34;
		data-flex-basis=&#34;583px&#34;
	
&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://airmuamua.github.io/hugoweb/p/b004/jtc5.png&#34;
	width=&#34;1879&#34;
	height=&#34;773&#34;
	srcset=&#34;https://airmuamua.github.io/hugoweb/p/b004/jtc5_hu_8717c27e995492c6.png 480w, https://airmuamua.github.io/hugoweb/p/b004/jtc5_hu_b631ccc4bba4398.png 1024w&#34;
	loading=&#34;lazy&#34;
	
